<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001-01" author="reviq">
        <createTable tableName="tenant">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="code" type="varchar(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="organization_name" type="varchar(200)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="tenant" indexName="idx_tenant_code">
            <column name="code"/>
        </createIndex>
        <createIndex tableName="tenant" indexName="idx_tenant_status">
            <column name="status"/>
        </createIndex>
    </changeSet>

    <changeSet id="001-02" author="reviq">
        <createTable tableName="tenant_database">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="uuid">
                <constraints nullable="false" unique="true" foreignKeyName="fk_tenant_database_tenant" references="tenant(id)"/>
            </column>
            <column name="db_host" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="db_port" type="int" defaultValueNumeric="5432">
                <constraints nullable="false"/>
            </column>
            <column name="db_name" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="db_username" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="db_password" type="varchar(500)">
                <constraints nullable="false"/>
            </column>
            <column name="management_schema_provisioned" type="boolean" defaultValueBoolean="false"/>
            <column name="ai_schema_provisioned" type="boolean" defaultValueBoolean="false"/>
            <column name="created_at" type="timestamp" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
