<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="003-01" author="reviq">
        <createTable tableName="tenant_api_key">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_api_key_tenant" references="tenant(id)"/>
            </column>
            <column name="name" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="key_prefix" type="varchar(16)">
                <constraints nullable="false"/>
            </column>
            <column name="key_hash" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="active" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="expires_at" type="timestamp"/>
            <column name="last_used_at" type="timestamp"/>
            <column name="version" type="bigint" defaultValueNumeric="0"/>
            <column name="created_at" type="timestamp" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="tenant_api_key" indexName="idx_api_key_prefix">
            <column name="key_prefix"/>
        </createIndex>
        <createIndex tableName="tenant_api_key" indexName="idx_api_key_tenant">
            <column name="tenant_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
