<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="007-01" author="reviq">
        <createTable tableName="sync_job">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="domain" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="started_at" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="finished_at" type="timestamp"/>
            <column name="records_processed" type="bigint" defaultValueNumeric="0"/>
            <column name="records_failed" type="bigint" defaultValueNumeric="0"/>
            <column name="error_message" type="text"/>
            <column name="created_at" type="timestamp" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="sync_job" indexName="idx_sync_job_domain_status">
            <column name="domain"/>
            <column name="status"/>
        </createIndex>
    </changeSet>

    <changeSet id="007-02" author="reviq">
        <createTable tableName="sync_log">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="sync_job_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_sync_log_job" references="sync_job(id)"/>
            </column>
            <column name="entity_type" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="erp_id" type="bigint"/>
            <column name="action" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="success" type="boolean">
                <constraints nullable="false"/>
            </column>
            <column name="error_message" type="text"/>
            <column name="created_at" type="timestamp" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
